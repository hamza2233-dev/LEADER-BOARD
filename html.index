<!DOCTYPE html>
<html>
<head>
    <title>BPO Performance Live</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #0b0e14; color: white; text-align: center; margin: 0; padding: 20px; }
        .container { max-width: 800px; margin: auto; background: #161b22; padding: 30px; border-radius: 12px; border: 1px solid #30363d; }
        h1 { color: #58a6ff; text-transform: uppercase; margin-bottom: 30px; }
        
        /* Leaderboard Table Styles */
        .board { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th { padding: 15px; background: #0d1117; color: #8b949e; text-transform: uppercase; font-size: 0.8rem; }
        td { padding: 15px; border-bottom: 1px solid #30363d; font-size: 1.1rem; font-weight: 500; }

        /* Status Colors */
        .row-approved { background: rgba(46, 160, 67, 0.15); color: #3fb950; border-left: 5px solid #3fb950; }
        .row-not-approved { background: rgba(248, 81, 73, 0.15); color: #f85149; border-left: 5px solid #f85149; }
        
        .status-badge { padding: 4px 12px; border-radius: 20px; font-size: 0.9rem; font-weight: bold; text-transform: uppercase; }
        .badge-approved { background: #238636; color: white; }
        .badge-not-approved { background: #da3633; color: white; }
    </style>
</head>
<body>

    <div class="container">
        <h1>Live Agent Performance</h1>
        <table class="board">
            <thead>
                <tr>
                    <th>Rank</th>
                    <th>Agent Name</th>
                    <th>Leads</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody id="leaderboard-data">
                <!-- Data will load here -->
            </tbody>
        </table>
    </div>

    <script>
        // PASTE YOUR GOOGLE SHEET CSV LINK HERE
        const csvUrl = "https://docs.google.com/spreadsheets/d/e/2PACX-1vRNUob6RgZZc4RWJfazbmerMCwcsZtJYulHpZk1FQPMm9rrnUKmTsTLzsXLaRGuEkDq_fuqIDGcAGAj/pubhtml";

        async function loadData() {
            try {
                const response = await fetch(csvUrl);
                const data = await response.text();
                const rows = data.split('\n').slice(1); // Skip header row
                
                let html = '';
                let agents = rows.map(row => {
                    const col = row.split(',');
                    return { 
                        name: col[0], 
                        leads: parseInt(col[1]) || 0, 
                        status: (col[2] || "").trim() 
                    };
                });

                // Sort by most leads
                agents.sort((a, b) => b.leads - a.leads);

                agents.forEach((agent, index) => {
                    // Check status for coloring
                    const isApproved = agent.status.toLowerCase() === "approved";
                    const rowClass = isApproved ? "row-approved" : "row-not-approved";
                    const badgeClass = isApproved ? "badge-approved" : "badge-not-approved";

                    html += `
                        <tr class="${rowClass}">
                            <td>#${index + 1}</td>
                            <td>${agent.name}</td>
                            <td>${agent.leads}</td>
                            <td><span class="status-badge ${badgeClass}">${agent.status}</span></td>
                        </tr>`;
                });

                document.getElementById('leaderboard-data').innerHTML = html;
            } catch (error) {
                console.error("Error loading CSV:", error);
            }
        }

        // Refresh every 20 seconds for the call center floor
        loadData();
        setInterval(loadData, 20000);
    </script>
</body>
</html>
